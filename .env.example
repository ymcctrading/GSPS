# GSPS market-data credentials — copy to `.env` and fill in. NEVER commit `.env`.
#
# Get these from the Alpaca dashboard (https://app.alpaca.markets) after signing
# up. Use PAPER trading keys first — real live prices, fake money, same code.
#
# When both are set, the app scans on the live Alpaca feed automatically.
# When they are absent, it falls back to the deterministic simulated feed.

# Key ID accepts any of: ALPACA_API_KEY_ID | ALPACA_API_KEY | APCA_API_KEY_ID
ALPACA_API_KEY_ID=
# Secret accepts any of: ALPACA_API_SECRET_KEY | ALPACA_SECRET_KEY | APCA_API_SECRET_KEY
ALPACA_API_SECRET_KEY=

# Data feed tier: "iex" (free) or "sip" (paid, full-market). Defaults to iex.
# ALPACA_FEED=iex
