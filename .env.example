# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Market-data provider selection: "alpaca", "synthetic", or unset.
# Unset = auto: use Alpaca when its keys are present, else synthetic demo data
# (so the public chart still renders with no keys configured).
MARKET_DATA_PROVIDER=

# Alpaca (data + paper trading). Live trading keys optional.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_API_SECRET=

# SnapTrade (optional — external brokerage linking is feature-flagged off without these)
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# Multi-provider market data (new providers)
# Binance: Public endpoint, no API key required for basic market data
# BINANCE_API_KEY= (optional, for advanced endpoints)

# Oanda: Forex/currency pairs data
OANDA_API_KEY=

# Twelve Data: Futures, stocks, indices, ETFs
TWELVE_DATA_API_KEY=

# Polygon.io: Stocks, crypto, options, forex
POLYGON_API_KEY=

# Secret required to invoke /api/market-scan (Vercel Cron sends it)
CRON_SECRET=

# Encryption key (32-byte base64) for broker credentials at rest
CREDENTIALS_ENCRYPTION_KEY=
